APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CENTRAL_ADMIN_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_QUEUE_CONNECTION=mysql
# Runtime app connection (least privilege, no CREATE DATABASE).
DB_PROVISIONING_CONNECTION=mysql_provisioning
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=central_app
DB_USERNAME=root
DB_PASSWORD=

# Dedicated provisioning connection (separate DB user with tenant DB create privileges).
# Recommendation: use a narrowly scoped provisioning user only for tenant provisioning operations.
DB_PROVISIONING_HOST=127.0.0.1
DB_PROVISIONING_PORT=3306
DB_PROVISIONING_DATABASE=information_schema
DB_PROVISIONING_USERNAME=root
DB_PROVISIONING_PASSWORD=

# Startup health check for provisioning credentials.
TENANCY_STARTUP_HEALTH_CHECK_ENABLED=true
TENANCY_HEALTH_CHECK_FAIL_FAST=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
